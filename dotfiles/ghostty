# Ghostty terminal emulator configuration file.
# The syntax is "key = value". The whitespace around the equals doesn't matter.
# REF:
# - https://github.com/search?q=path%3Aghostty%2Fconfig&type=code
# - https://github.com/mitchellh/ghostty/blob/main/src/config/Config.zig
# - https://github.com/mitchellh/ghostty/blob/main/src/input/Binding.zig
# Useful Tips:
# - ghostty +list-fonts
# - ghostty +list-themes

title = Ghostty!

# Favorite themes: Dracula, Dracula+, DoomOne, Doom Peacock, Desert, Earthsong
# Fairyfloss, GruvboxDark, Hopscotch, Monokai Remastered, Paraiso Dark, Rebecca, Seti
# Rippedcasts, Snazzy, Synthwave-Everything, Tinacious Design (Dark), TokyoNight, Wez
# Tomorrow Night Blue, Tomorrow Night Eighties, UltraDark, Wombat, Whimsy, WildCherry
theme = Desert
# Other Icons: blueprint, chalkboard, xray, microchip, glass, holographic, paper, retro
macos-icon = xray
background-opacity = 0.92
background-blur-radius = 30
unfocused-split-opacity = 0.95

#-----------Fonts Settings-----------#
font-size = 20
font-thicken = false
font-style = Regular
font-feature = +calt   # 启用上下文替代字形，根据周围字符调整字符形态
font-feature = +dlig   # 启用自由连字，额外的可选连字，超出标准集合
font-feature = +liga   # 启用标准连字，将常见字符组合如 fi, fl 转换成单个字形
# 更强的连字支持
font-feature = +hlig  # 启用历史连字，古老的传统连字组合
font-feature = +ss01  # 启用样式集 1（某些字体有额外的连字样式集）
font-feature = +ss02  # 启用 (Stylistic Sets 02): 风格集，提供特定风格的替代字形
font-feature = +cv01  # 字符变体（某些字体提供额外的字符变体）
font-feature = +cv03
# Does not work on macOS?
font-variation = wght=300
grapheme-width-method = unicode
# font-family = 0xProto
# font-family = Cascadia Code PL
# font-family = Sarasa Term SC
# https://www.jetbrains.com/lp/mono/
# font-family = JetBrains Mono
# REF: https://typeof.net/Iosevka/
# font-family = Iosevka Term Extended
# font-family = Hack Nerd Font Mono
# font-family = Source Code Pro
# font-family = Fira Code
# font-family = Geist Mono
font-family = MonoLisa Nerd Font Light
# font-family = Google Sans Code
# font-family = Lilex Regular
window-title-font-family = Fira Code
# 中文字体
# font-codepoint-map = U+4e00-U+9fa5=Maple Mono NF CN
# Use Fira Code for char g
# font-codepoint-map = U+0067-U+0067=Fira Code
# font-codepoint-map = U+4e00-U+9fa5=Sarasa Term SC

# window-decoration = false
gtk-titlebar = false
# This config does not work on macOS?
gtk-wide-tabs = false
window-width = 80
window-height = 20
window-theme = dark

# Variant: bar, block, underline, block_hollow
cursor-style = block_hollow
cursor-color = #eec36d
# cursor-color = #a8357a
cursor-opacity = 0.7
adjust-cursor-height = 60
adjust-cursor-thickness = 3

copy-on-select = clipboard
selection-foreground = #ffffff
selection-background = #7D717F
clipboard-paste-protection = true
clipboard-trim-trailing-spaces = true

scrollbar = never
mouse-hide-while-typing = true
macos-titlebar-style = transparent
macos-non-native-fullscreen = false

background-image-fit = cover
background-image-opacity = 0.05
background-image = ~/Documents/term-bg.png

keybind = command+right=next_tab
keybind = command+left=previous_tab
# keybind = command+h=toggle_visibility
keybind = command+shift+k=clear_screen
keybind = command+ctrl+shift+v=new_split:down
keybind = command+ctrl+shift+h=new_split:right

keybind = cmd+ctrl+up=resize_split:up,20
keybind = cmd+ctrl+down=resize_split:down,20
keybind = cmd+ctrl+left=resize_split:left,20
keybind = cmd+ctrl+right=resize_split:right,20

quick-terminal-screen = mouse
quick-terminal-position = bottom
keybind = global:cmd+grave_accent=toggle_quick_terminal
