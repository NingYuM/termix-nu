# Possible env value: DEV,TEST,STAGING,PROD
erda.test = [
    { pid = 1158, appid = 11338, appName = 'terp-ui', alias = 'terp', env = 'TEST', branch = 'develop', pipeline = 'pipeline.yml' },
    { pid = 1124, appid = 11147, appName = 'nusi-slim', alias = 'nusi', env = 'TEST', branch = 'develop', pipeline = '.erda/pipelines/nusi.yml' },
]

erda.dev = [
    { pid = 1158, appid = 11338, appName = 'terp-ui', alias = 'terp', env = 'DEV', branch = 'feature/latest', pipeline = 'pipeline.yml' },
    { pid = 1124, appid = 11147, appName = 'nusi-slim', alias = 'nusi', env = 'DEV', branch = 'feature/nusi', pipeline = '.erda/pipelines/nusi.yml' },
]

erda.staging = [
    { pid = 1158, appid = 11338, appName = 'terp-ui', alias = 'terp', env = 'STAGING', branch = 'release/latest', pipeline = 'pipeline.yml' }
]
