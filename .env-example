# A .env example file, copy it to .env and modify to fit your need.
# Do make sure that the .env file in the same dir with your Justfile
# Create soft link on Windows by cmd:
#   gsudo mklink /d "D:\Data\iWork\.env" "D:\Data\iWork\termix-nu\.env"
# Create soft link on Windows by pwsh:
#   gsudo New-Item -ItemType SymbolicLink -Path "D:\Data\iWork\.env" -Target "D:\Data\iWork\termix-nu\.env"

# The directory of termix-nu scripts, 该目录为 termix-nu clone 到本地的目录，不要填错了
TERMIX_DIR='/Users/terminus/termix-nu'
# 临时二开仓库存放目录, 请确保该目录存在
TERMIX_TMP_PATH='/Users/terminus/.termix-nu'
# 当前要打的后端版本号标签, 如果命令行里面传入为空则取该值
REDEV_CURRENT_TAG='v2.2.x'
# 待比较差异的上一个标签完整名称
REDEV_PREV_TAG='v2.2.0.12-2021.09.30'
# For dir-batch-exec and git-batch-exec script，批量执行命令时所用的脚本解释&执行器
SHELL_TO_RUN_CMD='bash'
# EMP emp_u_c_local 对应的 Cookie Value
EMP_UC_COOKIE='xx.yy.zz'
# EMP 工时填报查询ProjectCode参数配置
EMP_PROJECT_CODE='100'
# EMP 工时填报统计输出标题
EMP_WORKING_HOUR_TITLE='电商前端本周工时填报'
# 代码同步需要忽略推送的仓库简称，多个仓库用英文逗号分隔
SYNC_IGNORE_ALIAS=''

# 用户级别配置，每个开发者根据自己的情况配置, 请注意保密
# 这个配置用于执行 Erda Pipeline， 如果不需要可以不配置
ERDA_SESSION='92525ee0...'
